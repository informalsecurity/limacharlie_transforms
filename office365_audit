  "+USERNAME": "{{- $u := \"\" -}} {{- if .UserId }}{{ $u = printf \"%v\" .UserId }}{{ end -}} {{- if eq $u \"\" }}{{ if .UserKey }}{{ $u = printf \"%v\" .UserKey }}{{ end }}{{ end -}} {{- if eq $u \"\" }}{{ if .AppId }}{{ $u = printf \"%v\" .AppId }}{{ else if .ApplicationId }}{{ $u = printf \"%v\" .ApplicationId }}{{ else if .ClientAppId }}{{ $u = printf \"%v\" .ClientAppId }}{{ end }}{{ end -}} {{- if eq $u \"\" }}UNKNOWN{{ else }}{{ if ne (replace \"@\" \"\" $u) $u }}{{ index (split \"@\" $u) 0 }}{{ else }}{{ $u }}{{ end }}{{ end -}}",
